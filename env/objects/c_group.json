                        ],
                        "skipAcl": true
                      }
                    },
                    "configuration.televisit.roomsEnabled"
                  ]
                }
              },
              "in": {
                "$cond": {
                  "if": "$value",
                  "then": {
                    "$cond": [
                      "$$roomsEnabled",
                      true,
                      {
                        "$axon__throw_fault": {
                          "err_code": "axon.validationError.roomsMustBeEnableForTheOrg"
                        }
                      }
                    ]
                  },
                  "else": true
                }
              }
            }
